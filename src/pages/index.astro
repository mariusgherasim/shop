---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getAllProducts, getFeatured } from '../lib/products.js';

const all = getAllProducts();
const featured = getFeatured();
const picks = all.slice(0, 3);
---
<Layout current="home">
  <section class="hero">
    <div class="hero-dial" aria-hidden="true"><span class="hero-sweep"></span></div>
    <div class="container">
      <p class="eyebrow">Ediția curentă</p>
      <h1>Ceasuri și accesorii alese, nu doar listate.</h1>
      <p class="lede">
        Trecem prin zeci de modele ca să-ți arătăm doar pe cele care merită —
        cu prețul corect, specificațiile clare și oferta la zi.
      </p>
    </div>
  </section>

  <div class="container">
    <section class="section" style="padding-bottom: 0;">
      <div class="filters">
        <a class="filter-chip" href="/ceasuri">Ceasuri</a>
        <a class="filter-chip" href="/ochelari-de-soare">Ochelari de soare</a>
        <a class="filter-chip" href="/sub-150-lei">Sub 150 lei</a>
        <a class="filter-chip" href="/cadouri-pentru-el">Cadouri pentru el</a>
        <a class="filter-chip" href="/noutati">Noutăți</a>
        <a class="filter-chip" href="/oferte">Oferte</a>
      </div>
    </section>

    {picks.length > 0 && (
      <section class="section">
        <div class="section-head">
          <h2>Recomandările curente</h2>
        </div>
        <div class="product-grid">
          {picks.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

    {featured.length > 0 && (
      <section class="section">
        <div class="section-head">
          <h2>Oferta săptămânii</h2>
          <a href="/ofertele-saptamanii" class="eyebrow">Toate selecțiile →</a>
        </div>
        <div class="product-grid">
          {featured.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

    <section class="section">
      <Newsletter />
    </section>
  </div>
</Layout>
