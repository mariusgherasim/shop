---
import CollectionPage from '../../components/CollectionPage.astro';
import { getOffers } from '../../lib/products.js';

export async function getStaticPaths({ paginate }) {
  const products = getOffers();
  return paginate(products, { pageSize: 24 });
}

const { page } = Astro.props;
---
<CollectionPage
  title="Oferte active"
  current="oferte"
  page={page}
  emptyTitle="Nicio ofertă activă momentan"
  emptyText="Revino în curând — actualizăm ofertele regulat."
>
  {page.currentPage === 1 && (
    <div class="container" style="padding-bottom: 3rem;">
      <a href="/gravura-personalizata" class="gravura-banner">
        <div>
          <span class="eyebrow">Serviciu WatchShop.ro</span>
          <h3 style="margin: 0.2rem 0 0.2rem; font-family: var(--font-display);">Gravură personalizată — de la 100 Lei</h3>
          <p style="margin: 0; color: var(--color-steel);">Numele lui, data voastră, un mesaj de iubire — gravat pe capacul ceasului.</p>
        </div>
        <span class="price-btn">Vezi detalii →</span>
      </a>
    </div>
  )}
</CollectionPage>
