---
import CollectionPage from '../components/CollectionPage.astro';
import { getProductsByCategory } from '../lib/products.js';

const products = getProductsByCategory('cadouri-pentru-ea');
---
<CollectionPage
  title="Cadouri pentru ea"
  current="cadouri-pentru-ea"
  products={products}
  emptyTitle="Colecția pornește în curând"
  emptyText='Adaugă produse cu categoria "cadouri-pentru-ea" în src/data/products.json ca să apară aici.'
/>
